#!/bin/bash
# .app 더블클릭 → Electron 네이티브 셸 실행.
# Finder 에서 실행되면 PATH 가 최소화되므로 도구 위치를 직접 넣는다(node/pnpm/codex/claude).
# 이 PATH 는 Electron main → spawn 한 Next 서버 → codex/claude 로 그대로 상속된다.
# exec 로 교체 실행하여 Electron 이 .app 의 포그라운드 프로세스로 남는다.
export PATH="/opt/homebrew/bin:$HOME/.local/bin:/usr/bin:/usr/sbin:/bin:$PATH"
PROJECT_DIR="/Users/wonpyoung/Developer/workspace/image-generator"
cd "$PROJECT_DIR" || exit 1
exec "$PROJECT_DIR/node_modules/electron/dist/Electron.app/Contents/MacOS/Electron" "$PROJECT_DIR/electron/main.js"

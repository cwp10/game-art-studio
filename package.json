{
  "name": "game-art-studio",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--max-old-space-size=8192 next dev -H 127.0.0.1",
    "build": "next build --webpack && node scripts/build-mcp.mjs",
    "start": "cross-env NODE_OPTIONS=--max-old-space-size=8192 next start -H 127.0.0.1",
    "lint": "eslint",
    "app": "electron electron/main.js",
    "db:init": "tsx scripts/init-db.ts",
    "cleanup": "tsx scripts/cleanup.ts",
    "gen:poses": "tsx scripts/gen-pose-guides.ts",
    "probe": "node scripts/probe-codex-imagegen.mjs",
    "test": "tsx scripts/test-classify.ts && tsx scripts/test-directions.ts && tsx scripts/test-sprite-marker.ts",
    "test:e2e": "playwright test",
    "test:post": "tsx scripts/test-spritesheet.ts && tsx scripts/smoke-composite-transform.mts",
    "postinstall": "node scripts/postinstall.mjs",
    "dist:mac": "CSC_IDENTITY_AUTO_DISCOVERY=false pnpm build && electron-builder --mac",
    "dist:win": "pnpm build && electron-builder --win --x64",
    "pack:mac": "electron-builder --mac",
    "pack:win": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.maniplexsoft.game-art-studio",
    "productName": "Game Art Studio",
    "asar": false,
    "npmRebuild": false,
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**",
      "public/**",
      "node_modules/**",
      "package.json",
      "next.config.ts",
      "src/lib/db/**",
      "src/lib/prompt/**"
    ],
    "extraResources": [
      {
        "from": ".next",
        "to": "app/.next",
        "filter": [
          "**/*",
          "!cache/**"
        ]
      },
      {
        "from": "node_modules/.pnpm/@img+sharp-darwin-arm64@0.33.5/node_modules/@img/sharp-darwin-arm64",
        "to": "app/node_modules/@img/sharp-darwin-arm64"
      },
      {
        "from": "node_modules/.pnpm/@img+sharp-libvips-darwin-arm64@1.0.4/node_modules/@img/sharp-libvips-darwin-arm64",
        "to": "app/node_modules/@img/sharp-libvips-darwin-arm64"
      }
    ],
    "mac": {
      "target": "dir",
      "icon": "icon-assets/AppIcon.icns",
      "category": "public.app-category.graphics-design"
    },
    "win": {
      "target": "dir",
      "icon": "icon-assets/icon.png"
    }
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^11.5.0",
    "gif.js": "^0.2.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.469.0",
    "nanoid": "^5.0.9",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hotkeys-hook": "^4.6.1",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.12",
    "@types/gif.js": "^0.2.5",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^10.1.0",
    "electron": "^42.3.0",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "playwright": "^1.60.0",
    "tailwindcss": "^4",
    "tsx": "^4.19.2",
    "typescript": "^5"
  }
}

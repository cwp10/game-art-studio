{
  "name": "sprite-forge",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "NODE_OPTIONS=--max-old-space-size=4096 next dev -H 127.0.0.1",
    "build": "NODE_OPTIONS=--max-old-space-size=4096 next build",
    "start": "next start -H 127.0.0.1",
    "lint": "eslint",
    "app": "electron electron/main.js",
    "db:init": "tsx scripts/init-db.ts",
    "cleanup": "tsx scripts/cleanup.ts",
    "probe": "node scripts/probe-codex-imagegen.mjs",
    "postinstall": "cp -f node_modules/gif.js/dist/gif.worker.js public/gif.worker.js && /usr/libexec/PlistBuddy -c 'Set :CFBundleName Sprite Forge' node_modules/electron/dist/Electron.app/Contents/Info.plist 2>/dev/null; /usr/libexec/PlistBuddy -c 'Set :CFBundleDisplayName Sprite Forge' node_modules/electron/dist/Electron.app/Contents/Info.plist 2>/dev/null; true"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^11.5.0",
    "gif.js": "^0.2.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.469.0",
    "nanoid": "^5.0.9",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hotkeys-hook": "^4.6.1",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.12",
    "@types/gif.js": "^0.2.5",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "electron": "^42.3.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "playwright": "^1.60.0",
    "tailwindcss": "^4",
    "tsx": "^4.19.2",
    "typescript": "^5"
  }
}

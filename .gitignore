# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# image-generator runtime data — 폴더 자체는 추적하지 않되, 코드 구성인 mcp.json 만 예외.
# (폴더 전체 ignore 패턴 `/data/` 하에서는 negation 이 동작하지 않으므로 `/data/*` 사용.)
/data/*
!/data/mcp.json

# claude code per-user state
.claude/

# local plans
/.local-plans/


# typescript
*.tsbuildinfo
next-env.d.ts
